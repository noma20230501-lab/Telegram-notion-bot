TELEGRAM_BOT_TOKEN=1234567890:ABCDEF_your_telegram_bot_token
NOTION_TOKEN=ntn_your_notion_internal_integration_token
NOTION_DATABASE_ID=your_notion_database_id_32chars

# ─────────────────────────────────────────────────────────────
# [선택] 개인(관리자 전용) 노션 DB ID
# 이 값이 설정되면 모든 매물이 공유 DB + 개인 DB에 동시 저장됩니다.
# 신규 등록/수정/삭제/거래완료/추가사진 모두 양쪽 DB에 자동 반영.
# 개인 DB에도 동일한 Notion Integration 연결이 필요합니다.
# ─────────────────────────────────────────────────────────────
PRIVATE_NOTION_DATABASE_ID=

# ─────────────────────────────────────────────────────────────
# [선택] Cloudinary - 노션 사진 영구 저장 (텔레그램 URL 만료 대비)
# 가입: https://cloudinary.com (무료 플랜: 월 25GB 충분)
# Dashboard > API Keys 에서 아래 3개 값 복사
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
